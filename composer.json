{
    "name": "alexoliverwd/brace",
    "description": "A simple template language written in PHP",
    "keywords": [
        "handlebars",
        "template",
        "html"
    ],
    "license": "MIT",
    "authors": [
        {
            "name": "Alex Oliver",
            "homepage": "https://github.com/aoliverwd",
            "role": "Lead"
        }
    ],
    "support": {
        "issues": "https://github.com/aoliverwd/brace/issues"
    },
    "prefer-stable": true,
    "require": {
        "php": ">=8.4.1"
    },
    "autoload": {
        "psr-4": {
            "Brace\\": "src/"
        },
        "classmap": [
            "src/"
        ]
    },
    "require-dev": {
        "phpstan/phpstan": "^2.1",
        "phpunit/phpunit": "^13.1",
        "laravel/pint": "^1.29",
        "rector/rector": "^2.4"
    },
    "scripts": {
        "test": [
            "@static",
            "@unit"
        ],
        "static": [
            "./vendor/bin/phpstan analyse -c phpstan.neon"
        ],
        "unit": [
            "./vendor/bin/phpunit -c ./tests/phpunit.xml"
        ],
        "format": [
            "./vendor/bin/pint src --preset psr12"
        ]
    }
}
